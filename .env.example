# ----------------------------------------------------------------
# RUPIYA Café - Environment variables
# ----------------------------------------------------------------

# Database (PostgreSQL or Neon)
# For local PostgreSQL:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# For Neon serverless PostgreSQL (enable SSL automatically when host contains "neon.tech"):
# NEON_DATABASE_URL=postgresql://user:pass@ep-cool-name-123456.ap-southeast-1.aws.neon.tech/neondb?sslmode=verify-full

# ----------------------------------------------------------------
# Admin session signing secret (REQUIRED in production)
# Generate a new one with:  openssl rand -hex 32
# ----------------------------------------------------------------
ADMIN_SESSION_SECRET=2d1265fa64f59643049c0c310d5552ea3c621363f1b2180dbdfcccf2df48ff1e

# ----------------------------------------------------------------
# Setup endpoint protection (REQUIRED in production)
# ----------------------------------------------------------------
SETUP_SECRET=replace-with-a-long-random-setup-token

# ----------------------------------------------------------------
# Optional Vercel Blob image storage
# If this is not set, admin uploads are stored in PostgreSQL as BYTEA blobs.
# ----------------------------------------------------------------
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ----------------------------------------------------------------
# Default admin (seeded on first run if no admin exists)
# ----------------------------------------------------------------
# username: admin
# password: RupiyaAdmin!2026
